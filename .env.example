# Inference provider (OpenRouter, Together, Groq, etc.)
INFERENCE_API_URL=https://openrouter.ai/api/v1/chat/completions
INFERENCE_API_KEY=your-api-key-here
INFERENCE_MODEL=meta-llama/llama-3-8b-instruct

# Worker pool tuning
MAX_WORKERS=10
CHUNK_SIZE=50
MAX_RETRIES=5
INITIAL_BACKOFF_SECONDS=1.0
MAX_BACKOFF_SECONDS=60.0

# Server
HOST=0.0.0.0
PORT=8000
JOBS_DIR=data/jobs
