# DigitalOcean Serverless Inference
DO_MODEL_ACCESS_KEY=
INFERENCE_API_URL=https://inference.do-ai.run/v1/chat/completions
INFERENCE_MODEL=llama3.3-70b-instruct

# Worker pool tuning
MAX_WORKERS=10
CHUNK_SIZE=50
MAX_RETRIES=5
INITIAL_BACKOFF_SECONDS=1
MAX_BACKOFF_SECONDS=60

# DO Spaces (optional — enables chunk upload on seal)
SPACES_KEY=
SPACES_SECRET=
SPACES_BUCKET=
SPACES_REGION=nyc3

# Server
JOBS_DIR=data/jobs
PORT=8080
